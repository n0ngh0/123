// กำหนดว่าจะเชื่อมต่อกับ Database อะไร (เช่น PostgreSQL, MySQL)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// สร้างตาราง User
model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  password String
  role     String   @default("user") // 'user' หรือ 'admin'
  articles Article[] // 1 User มีได้หลาย Article
}

// สร้างตาราง Article
model Article {
  id       Int    @id @default(autoincrement())
  title    String
  authorId Int
  author   User   @relation(fields: [authorId], references: [id])
}